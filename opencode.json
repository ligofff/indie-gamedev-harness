{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "instructions": ["AGENTS.md"],
  "permission": {
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "git reset --hard*": "deny",
      "git clean -f*": "deny"
    },
    "read": {
      "**/.env*": "deny"
    }
  }
}
